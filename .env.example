# Environment Configuration Template
# Copy to .env and fill in your credentials
 
# ========== HUGGING FACE ==========
HF_TOKEN=
HF_MODEL=gpt-3.5-turbo-instruct
HF_API_ENDPOINT=https://api-inference.huggingface.co
 
# ========== GMAIL ==========
GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=./credentials/gmail_token.pickle
 
# ========== GITHUB ==========
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
 
# ========== SLACK ==========
SLACK_BOT_TOKEN=xoxb_your_token_here
SLACK_SIGNING_SECRET=your_secret_here
 
# ========== DATABASE ==========
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=autonomous_workos
POSTGRES_USER=ai
POSTGRES_PASSWORD=your_password_here
 
# ========== REDIS CACHE ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
 
# ========== VECTOR DATABASE ==========
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX=autonomous-workos
PINECONE_HOST=
PINECONE_MODEL=llama-text-embed-v2
 
# ========== ML/AI ==========
DEVICE=cpu  # or 'cuda' for GPU
BATCH_SIZE=32
NUM_WORKERS=4
MODEL_CACHE_DIR=./models
 
# ========== LOGGING & MONITORING ==========
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_DATADOG=false
DATADOG_API_KEY=
 
# ========== API SERVER ==========
API_HOST=0.0.0.0
API_PORT=7860
API_WORKERS=4
 
# ========== ENVIRONMENT ==========
ENVIRONMENT=development  # or 'production'
DEBUG=true
 
 